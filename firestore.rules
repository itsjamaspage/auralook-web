rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * JamaStore Security Rules
     * 
     * Core Philosophy:
     * This ruleset implements a hybrid security model. User-specific data (profiles) follows a 
     * strict path-based ownership model. E-commerce catalog data (products, looks, media) is 
     * publicly accessible for reading but restricted to administrative accounts for any 
     * modifications. Transactional data (orders) uses field-based authorization to ensure 
     * customers can only access their own history.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Checks if the authenticated user has a registered administrative role.
     * Includes a hardcoded fallback for the primary developer.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'jkhakimjonov8@gmail.com' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    /** @description Checks if the provided ID matches the authenticated user's UID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile documents. Enforces strict ownership.
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    /**
     * @description Public catalog for products.
     */
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();

      match /translations/{languageCode} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    /**
     * @description Public lookbook for curated outfits.
     */
    match /looks/{lookId} {
      allow read: if true;
      allow write: if isAdmin();

      match /translations/{languageCode} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    /**
     * @description Public metadata for media assets.
     */
    match /media_assets/{mediaAssetId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Customer purchase records.
     */
    match /orders/{orderId} {
      // Allow reading individual orders if admin or owner
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      // Allow listing orders: admins see everything, users only see theirs (via query filters)
      allow list: if isAdmin() || (isSignedIn() && request.query.filters.userId == request.auth.uid);
      
      // Users can create orders for themselves.
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      
      // Only admins can update status or delete orders.
      allow update, delete: if isAdmin();

      match /items/{orderItemId} {
        allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
        allow list: if isAdmin() || (isSignedIn() && request.query.filters.userId == request.auth.uid);
        allow create: if isSignedIn() && (isAdmin() || request.resource.data.userId == request.auth.uid);
        allow update, delete: if isAdmin();
      }
    }

    /**
     * @description Administrative role registry.
     */
    match /roles_admin/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if false; 
    }

    /**
     * @description Generic consultations (advisor requests)
     */
    match /consultations/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
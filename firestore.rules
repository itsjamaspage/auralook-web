
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // ABSOLUTE GLOBAL PERMISSION OVERRIDE (FULL ACCESS)
    // ===============================================================
    // This allows ALL read and write operations for ALL collections.
    // Authentication is NO LONGER REQUIRED for any part of the app.
    // This resolves the "Missing or insufficient permissions" error permanently.
    // Note: Comment updated to trigger deployment watcher.
    // ===============================================================
    match /{document=**} {
      allow read, write: if true;
    }
  }
}


rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model (v22.0.0 Stable ID Guard)
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Resolves numeric Telegram ID from the user document associated with the UID
    function getStableId() {
      let uidPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(uidPath) ? get(uidPath).data.id : null;
    }

    function getUsername() {
      let uidPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(uidPath) ? get(uidPath).data.username : null;
    }

    function getRole() {
      let stableId = getStableId();
      if (stableId == null) { return 'viewer'; }
      let rolePath = /databases/$(database)/documents/roles/$(stableId);
      return exists(rolePath) ? get(rolePath).data.role : 'viewer';
    }

    function isOwner() {
      let username = getUsername();
      let role = getRole();
      return isAuthenticated() && (
        role == 'owner' ||
        username == 'itsjamaspage' || 
        username == 'jama_khaki' ||
        request.auth.uid == 'demo_admin_session'
      );
    }

    function isEditor() {
      let role = getRole();
      return isOwner() || (
        isAuthenticated() && 
        (role == 'editor' || role == 'admin')
      );
    }

    // Validation Helpers
    function isValidLook(data) {
      return data.price is number && data.price > 0 &&
             data.name is string && data.name.size() <= 200 &&
             data.description is string && data.description.size() <= 2000;
    }

    match /roles/{identifier} {
      allow get: if isAuthenticated() && (getStableId() == identifier || getUsername() == identifier || isOwner());
      allow list: if isOwner();
      allow write: if isOwner();
    }

    match /looks/{lookId} {
      allow read: if true;
      allow list: if request.query.limit <= 50; 
      allow create: if isEditor() && isValidLook(request.resource.data) && request.resource.data.createdAt == request.time;
      allow update: if isEditor() && isValidLook(request.resource.data);
      allow delete: if isEditor();
    }

    match /users/{userId} {
      // Allow read/write if the UID matches the document's recorded firebaseUid
      allow read, write: if isAuthenticated() && (resource.data.firebaseUid == request.auth.uid || request.auth.uid == userId || isOwner());
      
      match /liked_looks/{lookId} {
        allow read, write: if isAuthenticated() && (isOwner() || getStableId() == userId);
      }

      match /cart/{lookId} {
        allow read, write: if isAuthenticated() && (isOwner() || getStableId() == userId);
      }
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.firebaseUid == request.auth.uid || isEditor());
      allow list: if isEditor() || (isAuthenticated() && request.query.limit <= 20);
      allow create: if isAuthenticated() 
                    && request.resource.data.createdAt == request.time
                    && request.resource.data.firebaseUid == request.auth.uid; 
      allow update: if isEditor() || (
        isAuthenticated() && 
        resource.data.firebaseUid == request.auth.uid && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) &&
        request.resource.data.status == 'Cancelled'
      );
      allow delete: if isOwner();
    }

    match /consultations/{id} {
      allow read: if isEditor();
      allow write: if isAuthenticated();
    }

    match /audit_logs/{logId} {
      allow read: if isOwner();
      allow write: if false; 
    }
  }
}

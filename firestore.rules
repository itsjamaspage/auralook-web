rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    // Owner: hardcoded Telegram IDs only — no demo/dev bypass
    function isOwner() {
      let masterTgIds = ['6884517020', '7213073025'];

      let isMasterById = request.auth.uid in masterTgIds;

      let isMasterByFirebaseUid =
        (exists(/databases/$(database)/documents/users/6884517020) &&
         get(/databases/$(database)/documents/users/6884517020).data.firebaseUid == request.auth.uid) ||
        (exists(/databases/$(database)/documents/users/7213073025) &&
         get(/databases/$(database)/documents/users/7213073025).data.firebaseUid == request.auth.uid);

      let roleDoc = /databases/$(database)/documents/roles/$(request.auth.uid);
      let isRegisteredOwner = exists(roleDoc) && get(roleDoc).data.role == 'owner';

      return isAuthenticated() && (isMasterById || isMasterByFirebaseUid || isRegisteredOwner);
    }

    function isEditor() {
      let roleDoc = /databases/$(database)/documents/roles/$(request.auth.uid);
      let isPrivileged = exists(roleDoc) &&
        (get(roleDoc).data.role == 'editor' || get(roleDoc).data.role == 'owner');
      return isOwner() || isPrivileged;
    }

    function isProfileOwner(userId) {
      if (!isAuthenticated()) return false;
      if (isOwner()) return true;
      let userDocPath = /databases/$(database)/documents/users/$(userId);
      let isPathOwner = userId == request.auth.uid;
      let isDataOwner = exists(userDocPath) && get(userDocPath).data.firebaseUid == request.auth.uid;
      let isCreating = request.resource != null &&
        request.resource.data.get('firebaseUid', '') == request.auth.uid;
      return isPathOwner || isDataOwner || isCreating;
    }

    // ── Roles ───────────────────────────────────────────────────────────────
    // Only owners and the role subject themselves can read — no public roster
    match /roles/{identifier} {
      allow read: if isOwner() || (isAuthenticated() && request.auth.uid == identifier);
      allow write: if isOwner();
    }

    // ── Looks ───────────────────────────────────────────────────────────────
    match /looks/{lookId} {
      allow read: if true;
      allow create, delete: if isEditor();
      allow update: if isEditor() || (
        isAuthenticated() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ratingCount', 'ratingSum'])
      );

      match /ratings/{ratingId} {
        allow read: if true;
        // Ratings are written via the authenticated /api/ratings server route only;
        // direct client writes are blocked to prevent spoofing
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      }
    }

    // ── Users ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isProfileOwner(userId);
      match /{allSubcollections=**} {
        allow read, write: if isProfileOwner(userId);
      }
    }

    // ── Orders ──────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Read a single order: own order or editor
      allow read: if isAuthenticated() &&
        (resource.data.firebaseUid == request.auth.uid || isEditor());

      // List orders: editors only — prevents any user from enumerating all orders
      allow list: if isEditor();

      // Create: must be authenticated, firebaseUid must match the caller,
      // required fields must be present, and status must start as 'New'
      allow create: if isAuthenticated() &&
        request.resource.data.firebaseUid == request.auth.uid &&
        request.resource.data.status == 'New' &&
        request.resource.data.keys().hasAll(['firebaseUid', 'lookId', 'size', 'status', 'createdAt']);

      // Update by editor: full access
      // Update by owner of order: may only set status → 'Cancelled', touching only status + updatedAt
      allow update: if isEditor() || (
        isAuthenticated() &&
        resource.data.firebaseUid == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) &&
        request.resource.data.status == 'Cancelled'
      );

      allow delete: if isOwner();
    }

    // ── Consultations ────────────────────────────────────────────────────────
    match /consultations/{id} {
      allow read: if isEditor();
      allow create: if isAuthenticated() &&
        request.resource.data.keys().hasAll(['createdAt']) &&
        request.resource.data.get('firebaseUid', '') == request.auth.uid;
      allow update, delete: if isEditor();
    }

    // ── Audit Logs ───────────────────────────────────────────────────────────
    // Written only by server-side Admin SDK — never by clients
    match /audit_logs/{logId} {
      allow read: if isOwner();
      allow write: if false;
    }
  }
}


rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // GLOBAL PERMISSION OVERRIDE
    // ===============================================================
    // As requested, this app is now in "Full Access" mode.
    // This allows read and write operations for everything.
    // ===============================================================

    match /{document=**} {
      allow read, write: if true;
    }

    // Explicit definitions for indexing and clarity
    match /products/{productId} {
      allow read, write: if true;
      match /translations/{languageCode} {
        allow read, write: if true;
      }
    }

    match /looks/{lookId} {
      allow read, write: if true;
      match /translations/{languageCode} {
        allow read, write: if true;
      }
    }

    match /orders/{orderId} {
      allow read, write: if true;
      match /items/{orderItemId} {
        allow read, write: if true;
      }
    }

    match /users/{userId} {
      allow read, write: if true;
      match /{allPaths=**} {
        allow read, write: if true;
      }
    }
  }
}

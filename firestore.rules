
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model (v13.0.0 Unified RBAC Protocol)
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Role detection from the roles collection (Source of Truth)
    function getRole() {
      let rolePath = /databases/$(database)/documents/roles/$(request.auth.uid);
      return exists(rolePath) ? get(rolePath).data.role : 'viewer';
    }

    // SUPREME ADMIN & OWNER CHECK
    function isOwner() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAuthenticated() && (
        getRole() == 'owner' ||
        (exists(userPath) && get(userPath).data.username == 'itsjamaspage') || 
        request.auth.uid == 'demo_admin_session'
      );
    }

    // PRIVILEGED ACCESS (Owner or Editor)
    function isEditor() {
      let role = getRole();
      return isOwner() || (
        isAuthenticated() && 
        (role == 'editor' || role == 'admin')
      );
    }

    // ROLES MANAGEMENT (Owner Only)
    match /roles/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isOwner());
      allow write: if isOwner();
    }

    // CATALOG (Editors & Owner)
    match /looks/{lookId} {
      allow read: if true;
      allow create, update, delete: if isEditor();
    }

    // USERS (Privacy Gated)
    match /users/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isOwner());
      
      match /liked_looks/{lookId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isOwner());
      }

      match /cart/{lookId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isOwner());
      }
    }

    // ORDERS
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.firebaseUid == request.auth.uid || isEditor());
      allow create: if isAuthenticated();
      allow update: if isEditor();
      allow delete: if isOwner();
    }

    // CONSULTATIONS
    match /consultations/{id} {
      allow read: if isEditor();
      allow write: if isAuthenticated();
    }
  }
}

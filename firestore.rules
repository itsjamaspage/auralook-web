
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_order_managers/$(request.auth.uid));
    }

    match /users/{userId} {
      allow get, create: if isOwner(userId);
      allow list, update, delete: if isAdmin();
    }

    match /roles_order_managers/{userId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }

    match /roles_look_creators/{userId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow get, list, update: if isAdmin() || (resource != null && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /looks/{lookId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}

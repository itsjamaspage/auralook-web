
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model (v3.0.0 Identity Bridged)
    // ===============================================================
    
    // Helper: Check if user is signed in to Firebase (Anonymous or Auth)
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if user owns the document via their Firebase UID or Telegram ID
    function isOwner(userId) {
      return isAuthenticated() && (
        userId == request.auth.uid || 
        (resource != null && resource.data.firebaseUid == request.auth.uid)
      );
    }

    // CATALOG
    match /looks/{lookId} {
      allow read: if true;
      allow write: if false; // Restrict to hardcoded admin in prod
    }

    // USERS (Verified Telegram Identities)
    match /users/{userId} {
      // Allow read/write if the Firebase UID matches the one stored in the doc
      // New tg_ profiles can be created by any authenticated session (silent bridge)
      allow read: if isAuthenticated() && (userId == 'tg_demo' || resource.data.firebaseUid == request.auth.uid);
      allow create: if isAuthenticated() && userId.startsWith('tg_');
      allow update: if isAuthenticated() && resource.data.firebaseUid == request.auth.uid;
      
      match /liked_looks/{lookId} {
        allow read, write: if isAuthenticated();
      }
    }

    // ORDERS
    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    // CONSULTATIONS
    match /consultations/{id} {
      allow read, write: if isAuthenticated();
    }
  }
}


rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // ABSOLUTE GLOBAL PERMISSION OVERRIDE (FULL ACCESS)
    // ===============================================================
    // This allows ALL read and write operations for ALL collections.
    // Necessary for prototype stage with Telegram-only Identity sync.
    // Note: Re-deployed to ensure size/timestamp updates work smoothly.
    // ===============================================================
    match /{document=**} {
      allow read, write: if true;
    }
  }
}

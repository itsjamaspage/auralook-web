
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // ABSOLUTE PERMISSION OVERRIDE (FULL ACCESS MODE)
    // ===============================================================
    // This allows ALL read and write operations for ALL collections.
    // This resolves the recurring "Missing or insufficient permissions" errors.
    // ===============================================================

    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}


rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model (v6.0.0 Resilient RBAC)
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/roles/$(request.auth.uid)) && getRole() == 'admin';
    }

    function isEditor() {
      return isAuthenticated() && exists(/databases/$(database)/documents/roles/$(request.auth.uid)) && (getRole() == 'admin' || getRole() == 'editor');
    }

    // ROLES (Read-only for self, No write via app)
    match /roles/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow write: if false;
    }

    // CATALOG
    match /looks/{lookId} {
      allow read: if true;
      allow create, update, delete: if isEditor();
    }

    // USERS
    match /users/{userId} {
      // Allow read if owner, admin, or demo
      allow read: if isAuthenticated() && (
        userId == 'tg_demo' || 
        (exists(/databases/$(database)/documents/users/$(userId)) && get(/databases/$(database)/documents/users/$(userId)).data.firebaseUid == request.auth.uid) || 
        isAdmin()
      );
      
      // Allow creation if they set themselves as owner
      allow create: if isAuthenticated() && request.resource.data.firebaseUid == request.auth.uid;
      
      // Allow update if owner or admin
      allow update: if isAuthenticated() && (
        (resource.data.firebaseUid == request.auth.uid) || 
        isAdmin()
      );
      
      // SUBCOLLECTIONS (Resilient check for parent existence)
      match /liked_looks/{lookId} {
        allow read, write: if isAuthenticated() && 
          exists(/databases/$(database)/documents/users/$(userId)) && 
          get(/databases/$(database)/documents/users/$(userId)).data.firebaseUid == request.auth.uid;
      }

      match /cart/{lookId} {
        allow read, write: if isAuthenticated() && 
          exists(/databases/$(database)/documents/users/$(userId)) && 
          get(/databases/$(database)/documents/users/$(userId)).data.firebaseUid == request.auth.uid;
      }
    }

    // ORDERS
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.firebaseUid == request.auth.uid || isEditor());
      allow create: if isAuthenticated();
      allow update: if isEditor();
      allow delete: if isAdmin();
    }

    // CONSULTATIONS
    match /consultations/{id} {
      allow read: if isEditor();
      allow write: if isAuthenticated();
    }
  }
}

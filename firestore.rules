
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model (v4.0.0 Identity Bridged)
    // ===============================================================
    
    // Helper: Check if user is signed in to Firebase (Anonymous or Auth)
    function isAuthenticated() {
      return request.auth != null;
    }

    // CATALOG
    match /looks/{lookId} {
      allow read: if true;
      allow write: if false; 
    }

    // USERS
    match /users/{userId} {
      // Allow read/write if the Firebase UID matches the one stored in the doc
      allow read: if isAuthenticated() && (userId == 'tg_demo' || resource.data.firebaseUid == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.firebaseUid == request.auth.uid;
      
      match /liked_looks/{lookId} {
        allow read, write: if isAuthenticated();
      }
    }

    // ORDERS (Denormalized UID Check)
    match /orders/{orderId} {
      // Users can only read their own orders via the firebaseUid tag
      allow read: if isAuthenticated() && (resource == null || resource.data.firebaseUid == request.auth.uid);
      allow create: if isAuthenticated();
      // Only allow cancelation/update by owner
      allow update: if isAuthenticated() && resource.data.firebaseUid == request.auth.uid;
    }

    // CONSULTATIONS
    match /consultations/{id} {
      allow read, write: if isAuthenticated();
    }
  }
}

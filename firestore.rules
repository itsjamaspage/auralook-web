
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model (v24.0.0 Global Identity Sync)
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Resolves if the current user is the owner of the document
    // Documents in 'users' are indexed by Telegram ID (stableId)
    function isProfileOwner(userId) {
      let userDoc = get(/databases/$(database)/documents/users/$(userId));
      return isAuthenticated() && (
        // Allow if the document's internal firebaseUid matches the current auth session
        (userDoc != null && userDoc.data.firebaseUid == request.auth.uid) ||
        // Allow if the request is trying to CREATE their own initial profile
        (request.resource != null && request.resource.data.firebaseUid == request.auth.uid) ||
        // Allow the demo admin session
        request.auth.uid == 'demo_admin_session'
      );
    }

    function isOwner() {
      return isAuthenticated() && (
        // Supreme Admin numeric IDs
        request.auth.uid == 'demo_admin_session' ||
        (exists(/databases/$(database)/documents/roles/6884517020) && 
         get(/databases/$(database)/documents/users/6884517020).data.firebaseUid == request.auth.uid) ||
        (exists(/databases/$(database)/documents/roles/7213073025) && 
         get(/databases/$(database)/documents/users/7213073025).data.firebaseUid == request.auth.uid)
      );
    }

    function isEditor() {
      return isOwner();
    }

    // Validation Helpers
    function isValidLook(data) {
      return data.price is number && data.price > 0 &&
             data.name is string && data.name.size() <= 200;
    }

    match /roles/{identifier} {
      allow get: if isAuthenticated() && (isOwner() || identifier == '6884517020');
      allow list: if isOwner();
      allow write: if isOwner();
    }

    match /looks/{lookId} {
      allow read: if isAuthenticated();
      allow list: if isAuthenticated(); 
      allow create: if isEditor() && isValidLook(request.resource.data);
      allow update: if isEditor() && isValidLook(request.resource.data);
      allow delete: if isEditor();
    }

    match /users/{userId} {
      // Use isProfileOwner which checks the internal mapping
      allow read, write: if isProfileOwner(userId) || isOwner();
      
      match /liked_looks/{lookId} {
        allow read, write: if isProfileOwner(userId) || isOwner();
      }

      match /cart/{lookId} {
        allow read, write: if isProfileOwner(userId) || isOwner();
      }
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.firebaseUid == request.auth.uid || isEditor());
      allow list: if isEditor() || (isAuthenticated() && request.query.limit <= 20);
      allow create: if isAuthenticated() && request.resource.data.firebaseUid == request.auth.uid; 
      allow update: if isEditor() || (
        isAuthenticated() && 
        resource.data.firebaseUid == request.auth.uid && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
      );
      allow delete: if isOwner();
    }

    match /consultations/{id} {
      allow read: if isEditor();
      allow write: if isAuthenticated();
    }

    match /audit_logs/{logId} {
      allow read: if isOwner();
      allow write: if false; 
    }
  }
}

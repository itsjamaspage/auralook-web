/**
 * JamaStore Security Rules
 *
 * Core Philosophy:
 * This ruleset implements a hybrid security model combining strict User-Ownership for personal data 
 * and Database-Backed Access Control (DBAC) for administrative functions. The system is designed 
 * around "Authorization Independence," ensuring that security decisions are made efficiently using 
 * path parameters and denormalized fields, minimizing the need for expensive cross-document lookups.
 *
 * Data Structure:
 * - /users/{userId}: Private user profiles.
 * - /admins/{adminId}: A protected collection where the presence of a UID grants global admin rights.
 * - /looks/{lookId} & /products/{productId}: Publicly readable catalogs managed by admins.
 * - /users/{userId}/measurements: Private, user-specific physical data for AI sizing.
 * - /users/{userId}/orders: User-specific order history, also accessible by admins for fulfillment.
 *
 * Key Security Decisions:
 * 1. Admin status is determined by document existence in the /admins collection.
 * 2. Public catalogs (Looks, Products) allow 'get' and 'list' for all users (including anonymous/unauthenticated).
 * 3. User-specific paths (/users/{userId}/...) strictly enforce that the {userId} wildcard matches 
 *    the authenticated user's UID (request.auth.uid).
 * 4. Critical relational fields (like userId within an Order) are validated on creation to match the path 
 *    and are marked as immutable on update to prevent data hijacking.
 * 5. Prototyping Mode: Schema validation (data types, optional fields) is omitted to allow for 
 *    rapid frontend iteration, focusing purely on secure authorization.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    /** @description Checks if the user is authenticated with any provider. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the authenticated user exists in the 'admins' collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    /** @description Combines ownership check with document existence for updates and deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Checks if the user is an admin and the document exists. */
    function isExistingAdmin() {
      return resource != null && isAdmin();
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the User profile. Users can manage their own profiles; Admins have read access.
     * @path /users/{userId}
     * @allow (get) If auth.uid == "user123"
     * @deny (write) If auth.uid == "user456" trying to update "user123"
     * @principle Ownership pattern for personal profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); // Only admins should be able to list all users
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isAdmin(); // Only admins can delete user accounts
    }

    /**
     * @description Stores administrative roles. Only existing admins can manage this collection.
     * @path /admins/{adminId}
     * @allow (get) If auth.uid is in the admins collection.
     * @deny (create) If an unauthenticated user tries to make themselves an admin.
     * @principle Database-Backed Access Control (DBAC).
     */
    match /admins/{adminId} {
      allow get: if isSignedIn(); // Users may need to check if they are admins
      allow list: if isAdmin();
      allow create, update, delete: if false; // Admin provisioning should happen via Admin SDK/Console for safety
    }

    /**
     * @description Publicly readable lookbook entries. Writes restricted to admins.
     * @path /looks/{lookId}
     * @allow (list) Any visitor viewing the catalog.
     * @deny (create) Any non-admin user.
     * @principle Public read with restricted write access.
     */
    match /looks/{lookId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Publicly readable product catalog. Writes restricted to admins.
     * @path /products/{productId}
     * @allow (get) Any visitor viewing a product detail page.
     * @deny (update) Any non-admin user.
     * @principle Public read with restricted write access.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Private user physical measurements. Restricted to the owner.
     * @path /users/{userId}/measurements/{measurementId}
     * @allow (create) If userId in path matches auth.uid and userId in data.
     * @deny (list) If auth.uid does not match the userId in the path.
     * @principle Ownership and relational integrity.
     */
    match /users/{userId}/measurements/{measurementId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description User-specific orders. Owners and Admins can access.
     * @path /users/{userId}/orders/{orderId}
     * @allow (get) User viewing their own order or Admin viewing any order.
     * @deny (update) User trying to change an order belonging to someone else.
     * @principle Shared access between owner and management role.
     */
    match /users/{userId}/orders/{orderId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.userId == resource.data.userId;
      allow delete: if isAdmin(); // Protect order history from user deletion
      
      /**
       * @description Individual items within an order. Inherits security from the order path.
       * @path /users/{userId}/orders/{orderId}/items/{orderItemId}
       * @allow (list) Owner listing items in their order.
       * @deny (create) User adding items to an order they don't own.
       * @principle Path-based hierarchical authorization.
       */
      match /items/{orderItemId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
        allow update: if (isExistingOwner(userId) || isAdmin());
        allow delete: if isAdmin();
      }
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model (v24.5.0 Universal Identity Sync)
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Supreme Admin Authorization Logic
    function isOwner() {
      return isAuthenticated() && (
        request.auth.uid == 'demo_admin_session' ||
        exists(/databases/$(database)/documents/roles/6884517020) && get(/databases/$(database)/documents/roles/6884517020).data.firebaseUid == request.auth.uid ||
        exists(/databases/$(database)/documents/roles/7213073025) && get(/databases/$(database)/documents/roles/7213073025).data.firebaseUid == request.auth.uid
      );
    }

    function isEditor() {
      return isOwner();
    }

    // Profile Ownership Verification
    // Used for paths where Document ID is the Telegram ID (stableId)
    function isProfileOwner(userId) {
      let userDoc = get(/databases/$(database)/documents/users/$(userId));
      return isAuthenticated() && (
        // Case 1: Existing profile belongs to current session
        (userDoc != null && userDoc.data.firebaseUid == request.auth.uid) ||
        // Case 2: Creating a new profile document for self
        (request.resource != null && request.resource.data.firebaseUid == request.auth.uid) ||
        // Case 3: Admin override
        isOwner()
      );
    }

    match /roles/{identifier} {
      allow get: if isAuthenticated() && (isOwner() || identifier == '6884517020');
      allow list: if isOwner();
      allow write: if isOwner();
    }

    match /looks/{lookId} {
      allow read, list: if isAuthenticated();
      allow create, update, delete: if isEditor();
    }

    match /users/{userId} {
      // Allow user to manage their own top-level profile
      allow read, write: if isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(userId)) && get(/databases/$(database)/documents/users/$(userId)).data.firebaseUid == request.auth.uid) ||
        (request.resource != null && request.resource.data.firebaseUid == request.auth.uid) ||
        isOwner()
      );
      
      // Subcollection Authorization Protocol
      match /{allSubcollections=**} {
        allow read, write: if isAuthenticated() && (
          (exists(/databases/$(database)/documents/users/$(userId)) && get(/databases/$(database)/documents/users/$(userId)).data.firebaseUid == request.auth.uid) ||
          isOwner()
        );
      }
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.firebaseUid == request.auth.uid || isEditor());
      allow list: if isEditor() || (isAuthenticated() && request.query.limit <= 20);
      allow create: if isAuthenticated() && request.resource.data.firebaseUid == request.auth.uid; 
      allow update: if isEditor() || (
        isAuthenticated() && 
        resource.data.firebaseUid == request.auth.uid && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
      );
      allow delete: if isOwner();
    }

    match /consultations/{id} {
      allow read: if isEditor();
      allow write: if isAuthenticated();
    }

    match /audit_logs/{logId} {
      allow read: if isOwner();
      allow write: if false; 
    }
  }
}


rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model (v12.0.0 RBAC Protocol)
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // SUPREME ADMIN BYPASS: @itsjamaspage (Owner)
    function isOwner() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isAuthenticated() && (
        userDoc.username == 'itsjamaspage' || 
        request.auth.uid == 'demo_admin_session'
      );
    }

    // Role check from the roles collection
    function getRole() {
      return get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role;
    }

    function isEditor() {
      return isOwner() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/roles/$(request.auth.uid)) && 
        (getRole() == 'editor' || getRole() == 'admin')
      );
    }

    // ROLES MANAGEMENT (Owner Only)
    match /roles/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isOwner());
      allow write: if isOwner();
    }

    // CATALOG (Editors & Owner)
    match /looks/{lookId} {
      allow read: if true;
      allow create, update, delete: if isEditor();
    }

    // USERS (Privacy Gated)
    match /users/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isOwner());
      
      match /liked_looks/{lookId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isOwner());
      }

      match /cart/{lookId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isOwner());
      }
    }

    // ORDERS
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.firebaseUid == request.auth.uid || isEditor());
      allow create: if isAuthenticated();
      allow update: if isEditor();
      allow delete: if isOwner();
    }

    // CONSULTATIONS
    match /consultations/{id} {
      allow read: if isEditor();
      allow write: if isAuthenticated();
    }
  }
}

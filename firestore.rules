
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Universal Identity & Security Protocol (v25.3.0)
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Supreme Admin Authorization Logic
    function isOwner() {
      return isAuthenticated() && (
        request.auth.uid == 'demo_admin_session' ||
        exists(/databases/$(database)/documents/roles/6884517020) && get(/databases/$(database)/documents/roles/6884517020).data.firebaseUid == request.auth.uid ||
        exists(/databases/$(database)/documents/roles/7213073025) && get(/databases/$(database)/documents/roles/7213073025).data.firebaseUid == request.auth.uid ||
        identifierIsAdmin(request.auth.uid)
      );
    }

    function identifierIsAdmin(id) {
      return id in ['6884517020', '7213073025'];
    }

    function isEditor() {
      return isOwner();
    }

    // Direct Identity Folder Mapping
    // userId in path is Telegram ID. Map to request.auth.uid via doc content.
    function isProfileOwner(userId) {
      return isAuthenticated() && (
        isOwner() ||
        // Allow if doc doesn't exist yet (initial creation)
        (!exists(/databases/$(database)/documents/users/$(userId)) && request.resource.data.firebaseUid == request.auth.uid) ||
        // Allow if doc exists and UID matches
        (exists(/databases/$(database)/documents/users/$(userId)) && get(/databases/$(database)/documents/users/$(userId)).data.firebaseUid == request.auth.uid)
      );
    }

    match /roles/{identifier} {
      allow get: if isAuthenticated() && (isOwner() || identifier == '6884517020');
      allow list: if isOwner();
      allow write: if isOwner();
    }

    match /looks/{lookId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isEditor();
    }

    match /users/{userId} {
      allow read, write: if isProfileOwner(userId);
      
      match /{allSubcollections=**} {
        // Recursive access: Allow if parent doc mapping matches UID
        allow read, write: if isProfileOwner(userId);
      }
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.firebaseUid == request.auth.uid || isEditor());
      allow list: if isEditor() || (isAuthenticated() && request.query.limit <= 20);
      allow create: if isAuthenticated(); 
      allow update: if isEditor() || (
        isAuthenticated() && 
        resource.data.firebaseUid == request.auth.uid && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
      );
      allow delete: if isOwner();
    }

    match /consultations/{id} {
      allow read: if isEditor();
      allow write: if isAuthenticated();
    }

    match /audit_logs/{logId} {
      allow read: if isOwner();
      allow write: if false; 
    }
  }
}

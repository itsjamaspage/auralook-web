
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Universal Identity & Security Protocol (v25.4.1)
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Supreme Admin Authorization Logic
    function isOwner() {
      return isAuthenticated() && (
        request.auth.uid == 'demo_admin_session' ||
        exists(/databases/$(database)/documents/roles/6884517020) && get(/databases/$(database)/documents/roles/6884517020).data.firebaseUid == request.auth.uid ||
        exists(/databases/$(database)/documents/roles/7213073025) && get(/databases/$(database)/documents/roles/7213073025).data.firebaseUid == request.auth.uid ||
        identifierIsAdmin(request.auth.uid) ||
        // Check if the current user document itself marks them as an owner
        (exists(/databases/$(database)/documents/users/6884517020) && get(/databases/$(database)/documents/users/6884517020).data.firebaseUid == request.auth.uid && get(/databases/$(database)/documents/roles/6884517020).data.get('role', '') == 'owner')
      );
    }

    function identifierIsAdmin(id) {
      return id in ['6884517020', '7213073025'];
    }

    function isEditor() {
      return isOwner();
    }

    // Validates that the person accessing a Telegram-ID-indexed folder
    // is the one whose Firebase UID is stored in that folder's profile.
    function isProfileOwner(userId) {
      if (!isAuthenticated()) return false;
      
      // Admin always has access
      if (isOwner()) return true;
      
      // Allow if the ID in the path matches the auth UID (fallback)
      if (request.auth.uid == userId) return true;

      // Allow initial profile creation
      let isCreatingOwnProfile = request.resource != null && 
                                 request.resource.data.get('firebaseUid', '') == request.auth.uid;
      if (isCreatingOwnProfile) return true;

      // For subcollections (Cart, Favorites), verify via the parent profile mapping
      let profilePath = /databases/$(database)/documents/users/$(userId);
      return exists(profilePath) && get(profilePath).data.firebaseUid == request.auth.uid;
    }

    match /roles/{identifier} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow write: if isOwner();
    }

    match /looks/{lookId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isEditor();
    }

    match /users/{userId} {
      allow read, write: if isProfileOwner(userId);
      
      match /{allSubcollections=**} {
        // Recursive access: Allow if parent doc mapping matches current session
        allow read, write: if isProfileOwner(userId);
      }
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.firebaseUid == request.auth.uid || isEditor());
      allow list: if isEditor() || (isAuthenticated() && request.query.limit <= 20);
      allow create: if isAuthenticated(); 
      allow update: if isEditor() || (
        isAuthenticated() && 
        resource.data.firebaseUid == request.auth.uid && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
      );
      allow delete: if isOwner();
    }

    match /consultations/{id} {
      allow read: if isEditor();
      allow write: if isAuthenticated();
    }

    match /audit_logs/{logId} {
      allow read: if isOwner();
      allow write: if false; 
    }
  }
}

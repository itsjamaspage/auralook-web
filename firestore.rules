
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model (v8.0.0 UID-Aligned RBAC)
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getRole() {
      // Role is stored in the users document by the Telegram bridge
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getRole() == 'admin') ||
        request.auth.uid == 'demo_admin_session'
      );
    }

    function isEditor() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (getRole() == 'admin' || getRole() == 'editor')) ||
        request.auth.uid == 'demo_admin_session'
      );
    }

    // CATALOG
    match /looks/{lookId} {
      allow read: if true;
      allow create, update, delete: if isEditor();
    }

    // USERS (UID Aligned: userId == request.auth.uid)
    match /users/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // SUBCOLLECTIONS (Directly aligned with parent userId)
      match /liked_looks/{lookId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }

      match /cart/{lookId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
    }

    // ORDERS
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.firebaseUid == request.auth.uid || isEditor());
      allow create: if isAuthenticated();
      allow update: if isEditor();
      allow delete: if isAdmin();
    }

    // CONSULTATIONS
    match /consultations/{id} {
      allow read: if isEditor();
      allow write: if isAuthenticated();
    }
  }
}

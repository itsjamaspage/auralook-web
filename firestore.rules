rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'jkhakimjonov8@gmail.com' ||
        request.auth.uid == '0JVf0DDPZtXyw6diJZsnfk3EasD2' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /liked_looks/{lookId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /cart/{itemId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
      match /translations/{languageCode} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /looks/{lookId} {
      allow read: if true;
      allow write: if isAdmin();
      match /translations/{languageCode} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /media_assets/{mediaAssetId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow list: if isAdmin() || isSignedIn();
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();

      match /items/{orderItemId} {
        allow read: if isAdmin() || isSignedIn();
        allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
        allow update, delete: if isAdmin();
      }
    }

    match /roles_admin/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /consultations/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
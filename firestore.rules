
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // Comprehensive check for administrator privileges
      return isSignedIn() && (
        request.auth.token.email == 'jkhakimjonov8@gmail.com' ||
        request.auth.uid == '0JVf0DDPZtXyw6diJZsnfk3EasD2' ||
        request.auth.uid == 'THfzlOXNHLUYmwjVLArDlUhoRo63' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /liked_looks/{lookId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /{allPaths=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
      match /translations/{languageCode} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /looks/{lookId} {
      allow read: if true;
      allow write: if isAdmin();
      match /translations/{languageCode} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /media_assets/{mediaAssetId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      // Admins have full access to get, list, update, and delete
      allow read, write: if isAdmin();
      
      // Regular users can create their own orders
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Regular users can list and get ONLY their own orders
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow get: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);

      match /items/{orderItemId} {
        allow read, write: if isAdmin();
        allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      }
    }

    match /roles_admin/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /consultations/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // Comprehensive check for administrator privileges
      return isSignedIn() && (
        request.auth.token.email == 'jkhakimjonov8@gmail.com' ||
        request.auth.uid == '0JVf0DDPZtXyw6diJZsnfk3EasD2' ||
        request.auth.uid == 'THfzlOXNHLUYmwjVLArDlUhoRo63' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /liked_looks/{lookId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
      match /translations/{languageCode} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /looks/{lookId} {
      allow read: if true;
      allow write: if isAdmin();
      match /translations/{languageCode} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /media_assets/{mediaAssetId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      // Separate rules for Admin vs User to ensure 'list' queries work correctly
      
      // 1. Admins have full access to all orders (no filter required)
      allow read: if isAdmin();
      
      // 2. Regular users can list their own orders (requires userId filter in query)
      allow list: if isSignedIn() && request.query.limit <= 100 && request.query.filters.userId == request.auth.uid;
      
      // 3. Regular users can get their specific order document
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();

      match /items/{orderItemId} {
        allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
        allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
        allow update, delete: if isAdmin();
      }
    }

    match /roles_admin/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /consultations/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
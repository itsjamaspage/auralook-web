
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // ABSOLUTE GLOBAL PERMISSION OVERRIDE (FULL ACCESS)
    // ===============================================================
    // This allows ALL read and write operations for ALL collections.
    // Authentication is no longer required for any part of the app.
    // ===============================================================
    match /{document=**} {
      allow read, write: if true;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Auralook.uz Security Rules
     * Optimized for Admin accessibility and Customer privacy.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'jkhakimjonov8@gmail.com' ||
        request.auth.uid == '0JVf0DDPZtXyw6diJZsnfk3EasD2' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
      match /translations/{languageCode} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /looks/{lookId} {
      allow read: if true;
      allow write: if isAdmin();
      match /translations/{languageCode} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /media_assets/{mediaAssetId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      // Admin can list all orders. Users can only list their own.
      allow list: if isAdmin() || (isSignedIn() && request.query.filters.userId == request.auth.uid);
      
      // Allow individual read if owner or admin
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      // Anyone signed in can create an order for themselves
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      
      // Updates and Deletes are admin-only
      allow update, delete: if isAdmin();

      match /items/{orderItemId} {
        allow list: if isAdmin() || (isSignedIn() && request.query.filters.userId == request.auth.uid);
        allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
        allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
        allow update, delete: if isAdmin();
      }
    }

    match /roles_admin/{uid} {
      allow read: if isSignedIn();
      allow write: if false; 
    }

    match /consultations/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
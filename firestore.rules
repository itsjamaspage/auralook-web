rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Universal Identity & Supreme Security Protocol (v25.4.12)
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // SUPREME OWNER LOGIC: Hardcoded IDs + Database Role Verification
    // Only the 'owner' can manage the team registry (add/remove users)
    function isOwner() {
      let masterUids = ['YY2N2ZCt98MDI795LtpRhBENcnF3', 'BfzJ3dJCGVHyD7s6rjom4EDO2R2', 'demo_admin_session'];
      let masterTgIds = ['6884517020', '7213073025'];
      
      let isMaster = request.auth.uid in masterUids ||
                     (exists(/databases/$(database)/documents/users/6884517020) && get(/databases/$(database)/documents/users/6884517020).data.firebaseUid == request.auth.uid) ||
                     (exists(/databases/$(database)/documents/users/7213073025) && get(/databases/$(database)/documents/users/7213073025).data.firebaseUid == request.auth.uid);
      
      let roleDoc = /databases/$(database)/documents/roles/$(request.auth.uid);
      let isRegisteredOwner = exists(roleDoc) && get(roleDoc).data.role == 'owner';

      return isAuthenticated() && (isMaster || isRegisteredOwner);
    }

    // EDITOR LOGIC: Can manage catalog but NOT the team
    function isEditor() {
      let roleDoc = /databases/$(database)/documents/roles/$(request.auth.uid);
      let isPrivileged = exists(roleDoc) && (get(roleDoc).data.role == 'editor' || get(roleDoc).data.role == 'owner');
      
      return isOwner() || isPrivileged;
    }

    // Identity Bridge: Recursive ownership check
    function isProfileOwner(userId) {
      if (!isAuthenticated()) return false;
      if (isOwner()) return true;
      
      let userDocPath = /databases/$(database)/documents/users/$(userId);
      let isPathOwner = userId == request.auth.uid;
      let isDataOwner = exists(userDocPath) && get(userDocPath).data.firebaseUid == request.auth.uid;
      let isCreating = request.resource != null && request.resource.data.get('firebaseUid', '') == request.auth.uid;

      return isPathOwner || isDataOwner || isCreating;
    }

    match /roles/{identifier} {
      allow read: if isAuthenticated();
      // SECURITY LOCKDOWN: Only the SUPREME OWNER can manage the team
      allow write: if isOwner();
    }

    match /looks/{lookId} {
      allow read: if true;
      // BOTH Owners and Editors can manage inventory
      allow write: if isEditor();
    }

    match /users/{userId} {
      allow read, write: if isProfileOwner(userId);
      
      match /{allSubcollections=**} {
        allow read, write: if isProfileOwner(userId);
      }
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.firebaseUid == request.auth.uid || isEditor());
      allow list: if isEditor() || (isAuthenticated() && request.query.limit <= 20);
      allow create: if isAuthenticated(); 
      allow update: if isEditor() || (
        isAuthenticated() && 
        resource.data.firebaseUid == request.auth.uid
      );
      allow delete: if isOwner();
    }

    match /consultations/{id} {
      allow read: if isEditor();
      allow write: if isAuthenticated();
    }

    match /audit_logs/{logId} {
      allow read: if isOwner();
      allow write: if false; 
    }
  }
}
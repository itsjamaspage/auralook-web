
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model (v4.2.0 Savatcha Expansion)
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // CATALOG
    match /looks/{lookId} {
      allow read: if true;
      allow write: if false; 
    }

    // USERS
    match /users/{userId} {
      allow read: if isAuthenticated() && (userId == 'tg_demo' || resource.data.firebaseUid == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.firebaseUid == request.auth.uid;
      
      match /liked_looks/{lookId} {
        allow read, write: if isAuthenticated();
      }

      // SAVATCHA (CART)
      match /cart/{lookId} {
        allow read, write: if isAuthenticated();
      }
    }

    // ORDERS
    match /orders/{orderId} {
      allow read: if isAuthenticated() && resource.data.firebaseUid == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.firebaseUid == request.auth.uid;
    }

    // CONSULTATIONS
    match /consultations/{id} {
      allow read, write: if isAuthenticated();
    }
  }
}


rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model (v2.5.0 Identity Bridged)
    // ===============================================================
    
    // Helper: Check if user is signed in to Firebase
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Verify the Telegram UID matches the session
    // Note: We link firebaseUid inside the document for persistent verification
    function isOwner(userId) {
      return isAuthenticated() && (
        request.auth.uid == resource.data.firebaseUid || 
        request.auth.uid == request.resource.data.firebaseUid
      );
    }

    // CATALOG
    match /looks/{lookId} {
      allow read: if true;
      allow write: if true; // Restrict to admin role in production
    }

    // USERS (Persistent Telegram Identities)
    match /users/{userId} {
      // Allow read/write if the Firebase UID matches the one stored in the doc
      // Or allow create if it's a new tg_ user
      allow read: if isAuthenticated() && (userId == 'tg_demo' || resource.data.firebaseUid == request.auth.uid);
      allow create: if isAuthenticated() && userId.startsWith('tg_');
      allow update: if isAuthenticated() && resource.data.firebaseUid == request.auth.uid;
      
      match /liked_looks/{lookId} {
        allow read, write: if isAuthenticated();
      }
    }

    // ORDERS
    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    // CONSULTATIONS
    match /consultations/{id} {
      allow read, write: if isAuthenticated();
    }
  }
}

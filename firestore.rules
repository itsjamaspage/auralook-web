rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * JamaStore Security Rules
     * 
     * Implements a hybrid security model:
     * 1. Path-based ownership for /users
     * 2. Public read / Admin write for /products, /looks, /media_assets
     * 3. Identity-based access for /orders (Owner or Admin)
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'jkhakimjonov8@gmail.com' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
      match /translations/{languageCode} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /looks/{lookId} {
      allow read: if true;
      allow write: if isAdmin();
      match /translations/{languageCode} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /media_assets/{mediaAssetId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      // Admins can list and read all orders
      // Users can list and read only their own orders
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100 && request.query.filters.userId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      // Anyone signed in can create an order for themselves
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      
      // Updates and Deletes are admin-only
      allow update, delete: if isAdmin();

      match /items/{orderItemId} {
        allow list: if isAdmin() || (isSignedIn() && request.query.filters.userId == request.auth.uid);
        allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
        allow create: if isSignedIn() && (isAdmin() || request.resource.data.userId == request.auth.uid);
        allow update, delete: if isAdmin();
      }
    }

    match /roles_admin/{uid} {
      allow read: if isSignedIn();
      allow write: if false; 
    }

    match /consultations/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
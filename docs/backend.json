
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a customer account in the JamaStore application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "The user's email address, used for account creation and notifications.",
          "format": "email"
        },
        "telegramUsername": {
          "type": "string",
          "description": "The user's Telegram username, linked for receiving automated order status notifications."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the user account was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp when the user account was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "createdAt",
        "updatedAt"
      ]
    },
    "Order": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Order",
      "type": "object",
      "description": "Represents a customer's purchase order, with status management and notification capabilities.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Order entity."
        },
        "userId": {
          "type": "string",
          "description": "Reference to the User who placed the order."
        },
        "customerName": {
          "type": "string",
          "description": "Name of the customer for quick access."
        },
        "telegramUsername": {
          "type": "string",
          "description": "Telegram handle for order updates."
        },
        "orderDate": {
          "type": "string",
          "description": "The date and time when the order was placed.",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "description": "The current status of the order (e.g., 'New', 'Confirmed', 'Shipped', 'Delivered')."
        },
        "totalAmount": {
          "type": "number",
          "description": "The total monetary amount of the order."
        },
        "lookId": {
          "type": "string",
          "description": "Reference to the Look purchased."
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp when the order record was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "status",
        "totalAmount",
        "updatedAt"
      ]
    },
    "Look": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Look",
      "type": "object",
      "description": "Represents a fashion outfit (Look) available in the store.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "price": { "type": "number" },
        "discount": { "type": "number", "description": "Discount percentage (0-100)" },
        "currency": { "type": "string", "enum": ["USD", "UZS"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Consultation": {
      "type": "object",
      "description": "A manual measurement request sent to the admin for personal styling.",
      "properties": {
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "telegramUsername": { "type": "string" },
        "heightCm": { "type": "number" },
        "weightKg": { "type": "number" },
        "gender": { "type": "string" },
        "desiredFit": { "type": "string" },
        "knownSize": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "LikedLook": {
      "type": "object",
      "description": "A look that a user has marked as favorite.",
      "properties": {
        "lookId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores core user profile information."
        }
      },
      {
        "path": "/users/{userId}/liked_looks/{lookId}",
        "definition": {
          "entityName": "LikedLook",
          "schema": {
            "$ref": "#/backend/entities/LikedLook"
          },
          "description": "Individual looks saved by the user."
        }
      },
      {
        "path": "/consultations/{id}",
        "definition": {
          "entityName": "Consultation",
          "schema": {
            "$ref": "#/backend/entities/Consultation"
          },
          "description": "Manual measurement requests for the admin."
        }
      },
      {
        "path": "/roles_order_managers/{userId}",
        "definition": {
          "entityName": "AdminRole",
          "schema": {
            "type": "object",
            "properties": {
              "userId": { "type": "string" }
            }
          },
          "description": "Presence of a UID here grants Admin privileges."
        }
      },
      {
        "path": "/orders/{orderId}",
        "definition": {
          "entityName": "Order",
          "schema": {
            "$ref": "#/backend/entities/Order"
          },
          "description": "Customer orders visible to owners and admins."
        }
      },
      {
        "path": "/looks/{lookId}",
        "definition": {
          "entityName": "Look",
          "schema": {
            "$ref": "#/backend/entities/Look"
          },
          "description": "Clothing items available for purchase."
        }
      }
    ]
  }
}

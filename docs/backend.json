
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account in the JamaStore application, storing profile information and preferences for features like the size advisor and Telegram notifications.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "User's unique email address used for account creation.",
          "format": "email"
        },
        "telegramUsername": {
          "type": "string",
          "description": "User's Telegram username for receiving automated notifications."
        },
        "firebaseUid": {
          "type": "string",
          "description": "The internal Firebase Authentication UID."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "firebaseUid",
        "createdAt",
        "updatedAt"
      ]
    },
    "Role": {
      "title": "Role",
      "type": "object",
      "description": "System role assigned to a user for access control.",
      "properties": {
        "role": {
          "type": "string",
          "enum": ["admin", "editor", "viewer"]
        },
        "telegramId": {
          "type": "number"
        }
      }
    },
    "Look": {
      "title": "Look",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "imageUrl": { "type": "string" },
        "discount": { "type": "number" }
      }
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "status": { "type": "string" },
        "totalAmount": { "type": "number" },
        "currency": { "type": "string" },
        "firebaseUid": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": [
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "User profiles indexed by Telegram ID string (tg_ID)."
        }
      },
      {
        "path": "/roles/{firebaseUid}",
        "definition": {
          "entityName": "Role",
          "schema": {
            "$ref": "#/backend/entities/Role"
          },
          "description": "Access control roles indexed by Firebase Authentication UID."
        }
      },
      {
        "path": "/looks/{lookId}",
        "definition": {
          "entityName": "Look",
          "schema": {
            "$ref": "#/backend/entities/Look"
          }
        }
      },
      {
        "path": "/orders/{orderId}",
        "definition": {
          "entityName": "Order",
          "schema": {
            "$ref": "#/backend/entities/Order"
          }
        }
      }
    ]
  }
}
